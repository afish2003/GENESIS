# =============================================================================
# GENESIS Configuration — Dell OptiPlex 7090 (Controller)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is read by the controller on the OptiPlex.
# The HP Omen does NOT need this file — it only runs Ollama.
# =============================================================================

# ---------------------------------------------------------------------------
# Ollama inference endpoint (HP Omen 45L on LAN)
# ---------------------------------------------------------------------------
# Replace with the HP Omen's actual LAN IP. Find it with:
#   Windows (on Omen): ipconfig
#   Linux (on Omen):   ip addr show
OLLAMA_HOST=http://<OMEN_LAN_IP>:11434

# Model to use for all roles (agents, evaluator, summarizer)
# This model fits fully in the RTX 5090's 32 GB VRAM
OLLAMA_MODEL=qwen2.5:32b-instruct-q4_K_M

# ---------------------------------------------------------------------------
# Paths (relative to repo root — defaults work for standard setup)
# ---------------------------------------------------------------------------
WORLD_DIR=./world
WORLD_TEMPLATE_DIR=./world_template
RESEARCH_LOGS_DIR=./research_logs
PROMPTS_DIR=./prompts
KNOWLEDGE_BASES_DIR=./knowledge_bases

# ---------------------------------------------------------------------------
# Retrieval system
# ---------------------------------------------------------------------------
# Embedding model for reranking (runs on CPU on the OptiPlex)
EMBEDDING_MODEL=sentence-transformers/bge-small-en-v1.5

# BM25 candidate pool → reranked to top-k
BM25_CANDIDATE_POOL=20
RERANK_TOP_K=5

# ---------------------------------------------------------------------------
# Inference temperatures
# ---------------------------------------------------------------------------
# Discussion/reflection phases: higher for varied, natural output
TEMPERATURE_DISCUSSION=0.7

# Structured output phases (evaluation, memory, schemas): lower for reliability
TEMPERATURE_STRUCTURED=0.3
